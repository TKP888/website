# Cloudflare Stream (public embed). Copy to .env.local and fill in.
# Customer subdomain from Stream embed URL: customer-<THIS>.cloudflarestream.com
NEXT_PUBLIC_CF_STREAM_CUSTOMER_CODE=a8rtpoglvxtw27x9

# Hero showreel modal (optional; button hidden if unset)
NEXT_PUBLIC_CF_STREAM_VIDEO_UID_SHOWREEL=

# New Balance project detail carousel (optional; omit to hide video slide)
NEXT_PUBLIC_CF_STREAM_VIDEO_UID_NEW_BALANCE=b41bb9367479989880467f0be604738b

# Iconic Hotels & Resorts project detail carousel (optional; omit to hide video slides)
NEXT_PUBLIC_CF_STREAM_VIDEO_UID_ICONIC_HOTELS_AND_RESORT_1=
NEXT_PUBLIC_CF_STREAM_VIDEO_UID_ICONIC_HOTELS_AND_RESORT_2=

# Instagram photography feed (copy to .env.local; never commit tokens)
# 1. Create a Meta app with Instagram API (Instagram Login)
# 2. Generate a user token with instagram_business_basic for your Creator/Business account
# 3. Exchange for a long-lived token (~60 days):
#    curl "https://graph.instagram.com/access_token?grant_type=ig_exchange_token&client_secret=APP_SECRET&access_token=SHORT_LIVED_TOKEN"
INSTAGRAM_ACCESS_TOKEN=
NEXT_PUBLIC_INSTAGRAM_USERNAME=
